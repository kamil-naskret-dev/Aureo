{
  "extends": "@aureo/ts-config/nest",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false,
    "removeComments": true,
    "sourceMap": true,
    "declaration": true,
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
