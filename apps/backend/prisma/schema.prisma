generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserStatus {
  PENDING 
  ACTIVE
}

enum UserRole {
  USER
  ADMIN
}

enum TokenType {
  REFRESH
  EMAIL_VERIFY
  PASSWORD_RESET
}


model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  status    UserStatus @default(PENDING)
  role      UserRole   @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  profile         UserProfile?
  tokens          Token[]
  bans            Ban[]               @relation("BannedUser")
  bansIssued      Ban[]               @relation("BannedByAdmin")
  unbansIssued    Ban[]               @relation("UnbannedByAdmin")
  bookmarks       Bookmark[]
  bookmarkStates  UserBookmarkState[]
}

model UserProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  name         String
  avatarUrl    String?
  bio          String?
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Token {
  id        String    @id @default(cuid())
  userId    String
  type      TokenType
  token     String    @unique 
  expiresAt DateTime
  usedAt    DateTime?          
  userAgent String?           
  ipAddress String?            
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

// ─── Bookmarks ────────────────────────────────────────────────────────────────

model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  url         String   @db.VarChar(2048)
  title       String   @db.VarChar(500)
  description String?  @db.Text
  domain      String   @db.VarChar(253)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags       BookmarkTag[]
  userStates UserBookmarkState[]

  @@unique([userId, url])
  @@index([userId])
  @@index([domain])
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique @db.VarChar(50)
  createdAt DateTime    @default(now())

  bookmarks BookmarkTag[]
}

model BookmarkTag {
  bookmarkId String
  tagId      String

  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, tagId])
  @@index([tagId])
}

model UserBookmarkState {
  userId     String
  bookmarkId String
  pinned     Boolean   @default(false)
  pinnedAt   DateTime?
  archived   Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)

  @@id([userId, bookmarkId])
  @@index([userId, archived])
  @@index([userId, pinned])
}

// ──────────────────────────────────────────────────────────────────────────────

model Ban {
  id           String    @id @default(cuid())
  userId       String
  adminId      String
  reason       String
  bannedUntil  DateTime?          
  bannedAt     DateTime  @default(now())
  unbannedAt   DateTime?         
  unbannedById String?

  user       User  @relation("BannedUser",      fields: [userId],       references: [id], onDelete: Cascade)
  admin      User  @relation("BannedByAdmin",   fields: [adminId],      references: [id])
  unbannedBy User? @relation("UnbannedByAdmin", fields: [unbannedById], references: [id])

  @@index([userId])
}
