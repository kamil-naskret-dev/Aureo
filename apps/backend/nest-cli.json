{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/backend",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "projects": {
    "backend": {
      "type": "application",
      "root": "apps/backend",
      "entryFile": "main",
      "sourceRoot": "apps/backend/src",
      "compilerOptions": {
        "assets": ["mail/templates/**/*.hbs"],
        "watchAssets": true
      }
    }
  }
}
