<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Verify your Aureo account</title>
  </head>
  <body
    style="margin:0;padding:0;background:#f4f4f5;font-family:'Segoe UI',Arial,sans-serif;"
  >
    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='background:#f4f4f5;padding:48px 0;'
    >
      <tr>
        <td align='center'>
          <table
            width='560'
            cellpadding='0'
            cellspacing='0'
            style='background:#ffffff;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);'
          >

            <!-- Header -->
            <tr>
              <td style='background:#18181b;padding:28px 40px;'>
                <span
                  style='color:#ffffff;font-size:22px;font-weight:700;letter-spacing:-0.3px;'
                >Aureo</span>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style='padding:40px;'>
                <h2
                  style='margin:0 0 12px;color:#18181b;font-size:20px;font-weight:600;line-height:1.3;'
                >
                  Verify your email address
                </h2>
                <p
                  style='margin:0 0 28px;color:#71717a;font-size:15px;line-height:1.65;'
                >
                  Thanks for signing up for Aureo! Click the button below to
                  verify your email address and activate your account.
                </p>
                <a
                  href='{{verificationUrl}}'
                  style='display:inline-block;background:#18181b;color:#ffffff;text-decoration:none;padding:13px 28px;border-radius:7px;font-size:15px;font-weight:500;letter-spacing:0.1px;'
                >
                  Verify email
                </a>
                <p
                  style='margin:32px 0 0;color:#a1a1aa;font-size:13px;line-height:1.6;'
                >
                  If you didn't create an Aureo account, you can safely ignore
                  this email.<br />
                  This link will expire in
                  <strong>24 hours</strong>.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style='padding:20px 40px;border-top:1px solid #f4f4f5;'>
                <p style='margin:0;color:#a1a1aa;font-size:12px;'>
                  ©
                  {{year}}
                  Aureo. All rights reserved.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>